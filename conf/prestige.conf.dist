[worldserver]

########################################
# Prestige General Settings
########################################
#
#    Prestige.Enable
#        Description: Enable/Disable the prestige system.
#        Default:     0 - Disabled
#                     1 - Enabled
#

Prestige.Enable = 1

#
#    Prestige.AddonXpIndicator
#        Description: Send addon whisper updates (prefix PrestigeXP) so a client addon can show
#                     prestige XP toward the next prestige ding. Uses the same addon channel as
#                     mod-ale's Player:SendAddonMessage (RegisterAddonMessagePrefix on the client).
#                     If you use AIO + ALE with lua/z_prestige_aio_xp.lua, set this to 0 to avoid
#                     duplicate pushes (that script uses AIO.Handle instead).
#        Default:     1 - Enabled
#                     0 - Disabled (no addon traffic)
#

Prestige.AddonXpIndicator = 1

#
#    Prestige.ResetCost
#        Description: The cost of resetting attributes in copper.
#        Default:     0 (disabled)
#

Prestige.ResetCost = 0

#
#    Prestige.DisablePvP
#        Description: Enable/Disable the attributes in PvP combat.
#                     0 - Disabled
#        Default:     1 - Enabled
#

Prestige.DisablePvP = 1



########################################
# Prestige Stat Weights And Max
########################################
#
#    Prestige.Max.*
#        Description: The max amount of points that can be spent
#        Default:     100
#        Disable:     0
#
#       Keep in mind that Prestige.Max * Prestige.StatPerPoint CANNOT be greater than 65,536.
#           ex: if Prestige.Max.Stamina = 100 and Prestige.StatPerPoint.Stamina = 700, you will have errors due to overflow
#
Prestige.Max.Stamina = 50
Prestige.Max.Strength = 50
Prestige.Max.Agility = 50
Prestige.Max.Intellect = 50
Prestige.Max.Spirit = 50
Prestige.Max.SpellPower = 40
Prestige.Max.DefenseRating = 50
Prestige.Max.DodgeRating = 50
Prestige.Max.ParryRating = 50
Prestige.Max.BlockRating = 50
Prestige.Max.BlockValue = 50
Prestige.Max.CritRating = 50
Prestige.Max.HitRating = 50
Prestige.Max.ExpertiseRating = 50
Prestige.Max.HasteRating = 50
Prestige.Max.ArmorPenRating = 30
Prestige.Max.ResilRating = 50
Prestige.Max.AttackPower = 40
Prestige.Max.BonusArmor = 50
Prestige.Max.SpellPen = 50
Prestige.Max.Mp5 = 50
Prestige.Max.ResistFire = 50
Prestige.Max.ResistFrost = 50
Prestige.Max.ResistNature = 50
Prestige.Max.ResistShadow = 50
Prestige.Max.ResistArcane = 50
Prestige.Max.ResistAll = 30

#
#    Prestige.Max.*
#        Description: The max amount of points that can be spent
#        Default: varies
#
#       Keep in mind that Prestige.Max * Prestige.StatPerPoint CANNOT be greater than 65,536.
#           ex: if Prestige.Max.Stamina = 100 and Prestige.StatPerPoint.Stamina = 700, you will have errors due to overflow
#
Prestige.StatPerPoint.Stamina = 3
Prestige.StatPerPoint.Strength = 3
Prestige.StatPerPoint.Agility = 3
Prestige.StatPerPoint.Intellect = 3
Prestige.StatPerPoint.Spirit = 3
Prestige.StatPerPoint.SpellPower = 5
Prestige.StatPerPoint.DefenseRating = 5
Prestige.StatPerPoint.DodgeRating = 5
Prestige.StatPerPoint.ParryRating = 5
Prestige.StatPerPoint.BlockRating = 5
Prestige.StatPerPoint.BlockValue = 3
Prestige.StatPerPoint.CritRating = 5
Prestige.StatPerPoint.HitRating = 5
Prestige.StatPerPoint.ExpertiseRating = 5
Prestige.StatPerPoint.HasteRating = 5
Prestige.StatPerPoint.ArmorPenRating = 4
Prestige.StatPerPoint.ResilRating = 5
Prestige.StatPerPoint.AttackPower = 5
Prestige.StatPerPoint.BonusArmor = 15
Prestige.StatPerPoint.SpellPen = 5
Prestige.StatPerPoint.Mp5 = 5
Prestige.StatPerPoint.ResistFire = 5
Prestige.StatPerPoint.ResistFrost = 5
Prestige.StatPerPoint.ResistNature = 5
Prestige.StatPerPoint.ResistShadow = 5
Prestige.StatPerPoint.ResistArcane = 5
Prestige.StatPerPoint.ResistAll = 3

########################################
# Prestige Level Exp Formula
########################################
#
#    Prestige.LevelUpFormla.Type
#        Description: Sets the type of formula used for exp calculations. Note option 2 is experimental.
#               1 - Linear increase with rate. Total exp needed to level = base * (100+(prestigelvl*r)/100)
#               2 - Exponential increase with rate. Total exp needed to level = base * (1 + ((prestigelvl*r)/100) * (pow(prestigelvl,2)/k))
#        Default:     1
#      
Prestige.LevelUpFormula.Type = 1  

#
#    Prestige.LevelUpFormla.Base
#        Description: Controls the base value in the exp formula.
#        Default:     100000
#  
Prestige.LevelUpFormula.Base = 100000

#
#    Prestige.LevelUpFormla.r
#        Description: Controls the (r) multiplier in the exp formla. Higher rate = more exp needed to level
#        Default:     5
#    
Prestige.LevelUpFormula.r = 1

#
#    Prestige.LevelUpFormla.k
#        Description: Controls the (k) multiplier in the exp formla. Higher value = more exp needed to level. Only used if LevelupFormula.Type = 2
#        Default:     5
#    
Prestige.LevelUpFormula.k = 1
